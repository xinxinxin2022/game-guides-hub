---
import Layout from '../../../layouts/Layout.astro';

const guides = [
  { title: '纳维亚区域 - 完整金核/黑核收集攻略', url: '/game-guides-hub/zh/tower-of-fantasy/navia-collection', description: '纳维亚每个金核和黑核的位置,附带游戏内坐标、解谜方案和最优收集路线。' },
  { title: '源器机制新手指南', url: '/game-guides-hub/zh/tower-of-fantasy/source-mechanics', description: '掌握源器技能、理解元素反应,优化您的战斗循环。' },
  { title: '2026最佳队伍搭配', url: '/game-guides-hub/zh/tower-of-fantasy/team-comps', description: '适合各种玩法的更新队伍Build——从单人DPS到支援为主的副本阵容。' },
];
---

<Layout lang="zh" title="幻塔攻略 - 全收集与Build指南" description="完整的幻塔攻略,包含每个区域的收集路线、解谜方案和队伍搭配。">
  <article>
    <h1>🗼 幻塔攻略</h1>
    <p class="intro">幻塔的开放世界充满了收集品、解谜和隐藏秘密。我们的攻略专注于重要内容:带坐标的完整收集路线、高效的资源刷取和真正有效的队伍Build。</p>

    <div class="guide-grid">
      {guides.map(guide => (
        <a href={guide.url} class="guide-card">
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
          <span class="read-more">阅读攻略 →</span>
        </a>
      ))}
    </div>

    <section class="tips">
      <h2>💡 收集提示</h2>
      <ul>
        <li><strong>规划您的路线。</strong>不要漫无目的地跑——我们的攻略提供优化路径,让您不用走回头路。</li>
        <li><strong>检查前置条件。</strong>某些收集品需要特定的源器技能或任务完成。</li>
        <li><strong>使用地图。</strong>每个物品都包含游戏内坐标,让您可以传送到最近的传送点。</li>
        <li><strong>追踪您的进度。</strong>使用我们的清单,找到物品后勾选。</li>
      </ul>
    </section>
  </article>
</Layout>

<style>
  .intro {
    font-size: 1.125rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .guide-card {
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid #4a90d9;
    transition: background 0.3s, transform 0.3s;
    display: block;
  }

  .guide-card:hover {
    background: #f0f0f0;
    transform: translateX(4px);
    text-decoration: none;
  }

  .guide-card h3 {
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .guide-card p {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .read-more {
    color: #4a90d9;
    font-weight: 600;
  }

  .tips {
    background: #d1ecf1;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #17a2b8;
    margin-top: 3rem;
  }

  .tips h2 {
    border: none;
  }

  .tips li {
    margin-bottom: 1rem;
  }
</style>
