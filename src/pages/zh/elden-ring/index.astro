---
import Layout from '../../../layouts/Layout.astro';

const guides = [
  { title: '玛莲妮亚,米凯拉之刃 - 终极Boss攻略', url: '/zh/elden-ring/malenia-guide', description: '完整的招式拆解、逃课策略和最佳Build推荐,帮您击败艾尔登法环最难的Boss。' },
  { title: '最佳起始职业排名', url: '/zh/elden-ring/starting-classes', description: '全职业分析,适合近战、魔法和混合Build。找到最适合您玩法的起始职业。' },
  { title: '宁姆格福完整早期攻略', url: '/zh/elden-ring/limgrave-guide', description: '宁姆格福逐步路线,包含所有关键物品、武器和升级地点。' },
];
---

<Layout lang="zh" title="艾尔登法环攻略 - Boss战术与Build技巧" description="通过专业的Boss攻略、Build推荐和探索指南,掌握交界地的秘密。">
  <article>
    <h1>⚔️ 艾尔登法环攻略</h1>
    <p class="intro">欢迎,褪色者。这些攻略由在交界地度过数百小时的玩家编写。无论您是被Boss卡关、想要优化Build,还是刚刚开始旅程,我们都能帮到您。</p>

    <div class="guide-grid">
      {guides.map(guide => (
        <a href={guide.url} class="guide-card">
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
          <span class="read-more">阅读攻略 →</span>
        </a>
      ))}
    </div>

    <section class="tips">
      <h2>💡 新手快速提示</h2>
      <ul>
        <li><strong>先探索再战斗。</strong>很多Boss如果您先升级并找到更好的装备,就会变得简单。</li>
        <li><strong>使用灵魂骨灰。</strong>这不是"作弊"——它们是帮助您的核心机制。</li>
        <li><strong>先升级武器,再加属性。</strong>+10武器比+10力量造成的伤害更多。</li>
        <li><strong>阅读物品说明。</strong>FromSoftware在物品提示中隐藏了关键的任务信息。</li>
      </ul>
    </section>
  </article>
</Layout>

<style>
  .intro {
    font-size: 1.125rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .guide-card {
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid #c41e3a;
    transition: background 0.3s, transform 0.3s;
    display: block;
  }

  .guide-card:hover {
    background: #f0f0f0;
    transform: translateX(4px);
    text-decoration: none;
  }

  .guide-card h3 {
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .guide-card p {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .read-more {
    color: #c41e3a;
    font-weight: 600;
  }

  .tips {
    background: #fff3cd;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #ffc107;
    margin-top: 3rem;
  }

  .tips h2 {
    border: none;
  }

  .tips li {
    margin-bottom: 1rem;
  }
</style>
