    border-left: 4px solid #fcee09;
  }

  .weapon-card h3 {
    color: #d4a100;
    border: none;
    margin-top: 0;
  }

  .weapon-card table {
    margin: 1rem 0;
  }

  .by-build table {
    margin: 1rem 0;
  }

  .final-note {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    color: white;
    padding: 2rem;
    border-radius: 12px;
    margin-top: 3rem;
  }

  .final-note h2 {
    color: #fcee09;
    border: none;
  }

  .final-note a {
