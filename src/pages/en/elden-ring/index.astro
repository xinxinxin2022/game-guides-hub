---
import Layout from '../../../layouts/Layout.astro';

const guides = [
  { title: 'Malenia, Blade of Miquella - Ultimate Boss Guide', url: '/game-guides-hub/en/elden-ring/malenia-guide', description: 'Complete moveset breakdown, cheese strategies, and optimal builds for defeating Elden Ring\'s hardest boss.' },
  { title: 'Best Starting Classes Ranked', url: '/game-guides-hub/en/elden-ring/starting-classes', description: 'Every starting class analyzed for melee, magic, and hybrid builds. Find the perfect start for your playstyle.' },
  { title: 'Complete Limgrave Early Game Guide', url: '/game-guides-hub/en/elden-ring/limgrave-guide', description: 'Step-by-step route through Limgrave with all key items, weapons, and level-up spots mapped out.' },
];
---

<Layout title="Elden Ring Guides - Boss Strategies & Build Tips" description="Master Elden Ring with expert boss guides, build recommendations, and exploration walkthroughs for the Lands Between.">
  <article>
    <h1>⚔️ Elden Ring Guides</h1>
    <p class="intro">Welcome Tarnished. These guides are written by players who've spent hundreds of hours in the Lands Between. Whether you're stuck on a brutal boss, trying to optimize your build, or just starting your journey, we've got you covered.</p>

    <div class="guide-grid">
      {guides.map(guide => (
        <a href={guide.url} class="guide-card">
          <h3>{guide.title}</h3>
          <p>{guide.description}</p>
          <span class="read-more">Read Guide →</span>
        </a>
      ))}
    </div>

    <section class="tips">
      <h2>💡 Quick Tips for New Players</h2>
      <ul>
        <li><strong>Explore before you fight.</strong> Many bosses become trivial if you level up and find better gear first.</li>
        <li><strong>Use Spirit Ashes.</strong> They're not "cheating" — they're a core mechanic designed to help you.</li>
        <li><strong>Upgrade your weapon before your stats.</strong> A +10 weapon does more damage than +10 Strength.</li>
        <li><strong>Read item descriptions.</strong> FromSoftware hides critical quest information in item tooltips.</li>
      </ul>
    </section>
  </article>
</Layout>

<style>
  .intro {
    font-size: 1.125rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2rem;
  }

  .guide-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }

  .guide-card {
    background: #f9f9f9;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid #c41e3a;
    transition: background 0.3s, transform 0.3s;
    display: block;
  }

  .guide-card:hover {
    background: #f0f0f0;
    transform: translateX(4px);
    text-decoration: none;
  }

  .guide-card h3 {
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .guide-card p {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .read-more {
    color: #c41e3a;
    font-weight: 600;
  }

  .tips {
    background: #fff3cd;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #ffc107;
    margin-top: 3rem;
  }

  .tips h2 {
    border: none;
  }

  .tips li {
    margin-bottom: 1rem;
  }
</style>
